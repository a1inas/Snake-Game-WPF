<Window x:Class="Snake.RulesWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Snake"
      mc:Ignorable="d" 
      Height="700" Width="1200"
      ResizeMode="NoResize"
      Background="{StaticResource BackgroundColor}"
      Foreground="{StaticResource TextColor}"
      WindowStartupLocation="CenterScreen"
      Icon="Assets\iconsnake.ico"
      Title="Правила">


    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/background.png" Stretch="UniformToFill" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Width="124"
            Height="45"
            Margin="10,0,0,609"
            Background="Transparent"
            BorderThickness="0"
            Click="Back"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Content">
                        <Setter.Value>
                            <Image Source="/Assets/Back.png" Width="124" Height="45" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BackgroundColor}" />
                            <Setter Property="Content">
                                <Setter.Value>
                                    <Image Source="/Assets/Back_click.PNG" Width="124" Height="45" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        <Border Margin="250,30,250,40"
            BorderBrush="Black"
            BorderThickness="1"
            Background="{StaticResource BackgroundColor}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Ячейка 1 -->
                <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="ЗМЕЙКА 1"
                               FontSize="20"
                           HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                    <Image Source="/Assets/snake1.png"
                       Width="200"
                       Height="200" />
                </StackPanel>

                <!-- Ячейка 2  -->
                <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="ЗМЕЙКА 2"
                               FontSize="20"
                           HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                    <Image Source="/Assets/snake2.png"
                       Width="200"
                       Height="190" />
                </StackPanel>

                <!-- Ячейка 3 -->
                <TextBlock Text="Используйте ↑↓→← для управления змейкой1 или WASD для управления змейкой2 . Ешьте красные яблоки зеленой змейкой и лимоны голубой змейкой , но не врежьтесь в стену или в змейку!"
                       Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Margin="10"
                       MaxWidth="400"
                       TextWrapping="Wrap"
                       FontSize="19" />

                <!-- Ячейка 5 -->
                <Image Source="/Assets/arrows.png"
                   Width="150"
                   Height="150"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Grid.Row="2"
                   Grid.Column="0"
                   Margin="10"
                   Stretch="Uniform" />

                <!-- Ячейка 6 -->
                <Image Source="/Assets/kb.png"
                   Width="140"
                   Height="140"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Grid.Row="2"
                   Grid.Column="1"
                   Margin="10"
                   Stretch="Uniform" />

                

            </Grid>
        </Border>
    </Grid>
</Window>
